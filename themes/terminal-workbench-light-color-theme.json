  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5f6f67"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#007a4d"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#006f9e"
      }
    },
    {
      "name": "Template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#7357b8"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#b65800"
      }
    },
    {
      "name": "Keyword and storage",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7357b8"
      }
    },
    {
      "name": "Operator (quiet — adaptation from theme.css mint)",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#34443f"
      }
    },
    {
      "name": "Word-like operators stay keywords",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.wordlike",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#7357b8"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#006f9e"
      }
    },
    {
      "name": "Type and class (shares cyan with functions — adaptation)",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#006f9e"
      }
    },
    {
      "name": "Constant and number",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other",
        "variable.other.enummember",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#b65800"
      }
    },
    {
      "name": "Property and attribute",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "entity.other.attribute-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#a46600"
      }
    },
    {
      "name": "HTML/XML tag",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#c8324c"
      }
    },
    {
      "name": "YAML key (deeper scope beats entity.name.tag red)",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#a46600"
      }
    },
    {
      "name": "Variable and parameter",
      "scope": [
        "variable",
        "variable.parameter",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#17201d"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#60706a"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#c8324c"
      }
    },
    {
      "name": "MD h1",
      "scope": [
        "heading.1.markdown",
        "markup.heading.setext.1.markdown"
      ],
      "settings": {
        "foreground": "#17201d"
      }
    },
    {
      "name": "MD h2",
      "scope": [
        "heading.2.markdown",
        "markup.heading.setext.2.markdown"
      ],
      "settings": {
        "foreground": "#007a4d"
      }
    },
    {
      "name": "MD h3",
      "scope": [
        "heading.3.markdown"
      ],
      "settings": {
        "foreground": "#006f9e"
      }
    },
    {
      "name": "MD h4",
      "scope": [
        "heading.4.markdown"
      ],
      "settings": {
        "foreground": "#a46600"
      }
    },
    {
      "name": "MD h5/h6",
      "scope": [
        "heading.5.markdown",
        "heading.6.markdown"
      ],
      "settings": {
        "foreground": "#60706a"
      }
    },
