  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6f807b"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#63f2ab"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#6bdcff"
      }
    },
    {
      "name": "Template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#b78cff"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#f7a35c"
      }
    },
    {
      "name": "Keyword and storage",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#b78cff"
      }
    },
    {
      "name": "Operator (quiet — adaptation from theme.css mint)",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#b4c3bd"
      }
    },
    {
      "name": "Word-like operators stay keywords",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.wordlike",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#b78cff"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#6bdcff"
      }
    },
    {
      "name": "Type and class (shares cyan with functions — adaptation)",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#6bdcff"
      }
    },
    {
      "name": "Constant and number",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other",
        "variable.other.enummember",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#f7a35c"
      }
    },
    {
      "name": "Property and attribute",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "entity.other.attribute-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#f0c674"
      }
    },
    {
      "name": "HTML/XML tag",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff6e7a"
      }
    },
    {
      "name": "YAML key (deeper scope beats entity.name.tag red)",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#f0c674"
      }
    },
    {
      "name": "Variable and parameter",
      "scope": [
        "variable",
        "variable.parameter",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#dce4df"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#879994"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ff6e7a"
      }
    },
    {
      "name": "MD h1",
      "scope": [
        "heading.1.markdown",
        "markup.heading.setext.1.markdown"
      ],
      "settings": {
        "foreground": "#dce4df"
      }
    },
    {
      "name": "MD h2",
      "scope": [
        "heading.2.markdown",
        "markup.heading.setext.2.markdown"
      ],
      "settings": {
        "foreground": "#63f2ab"
      }
    },
    {
      "name": "MD h3",
      "scope": [
        "heading.3.markdown"
      ],
      "settings": {
        "foreground": "#6bdcff"
      }
    },
    {
      "name": "MD h4",
      "scope": [
        "heading.4.markdown"
      ],
      "settings": {
        "foreground": "#f0c674"
      }
    },
    {
      "name": "MD h5/h6",
      "scope": [
        "heading.5.markdown",
        "heading.6.markdown"
      ],
      "settings": {
        "foreground": "#879994"
